{
  "name": "api_city_states_br",
  "version": "1.1.0",
  "description": "API REST para consulta de estados e cidades brasileiras",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsx --watch src/main/index.ts",
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/main/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipefernandesdev/api_city_states_br.git"
  },
  "keywords": [
    "api",
    "brazil",
    "states",
    "cities",
    "ibge"
  ],
  "author": "Felipe Fernandes",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/felipefernandesdev/api_city_states_br/issues"
  },
  "homepage": "https://github.com/felipefernandesdev/api_city_states_br#readme",
  "dependencies": {
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/helmet": "^0.0.48",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.13",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
